import pandas as pd
import numpy as np
import matplotlib.pyplot as plt

df1=pd.read_csv('/Users/varanasisandeep/Downloads/archive (4)/2019-Oct.csv',nrows=500000)
print(df1.head())
df2=pd.read_csv('/Users/varanasisandeep/Downloads/archive (4)/2019-Nov.csv',nrows=500000)
print(df2.head())
df=pd.concat([df1,df2])
print(df.head())
print(df.info())
print(df.isnull().sum())
df.dropna(inplace=True)
print(df.isnull().sum())
print(df.info())
#Funnel Stage Calculation
views = (df["event_type"] == "view").sum()
carts = (df["event_type"] == "cart").sum()
purchases = (df["event_type"] == "purchase").sum()

print("Views:", views)
print("Carts:", carts)
print("Purchases:", purchases)
# rate conversion
view_to_cart = carts / views * 100
cart_to_purchase = purchases / carts * 100

print("View to Cart Conversion:", view_to_cart)
print("Cart to Purchase Conversion:", cart_to_purchase)
stages = ["View", "Cart", "Purchase"]
values = [views, carts, purchases]

plt.figure(figsize=(6,4))

plt.bar(stages, values)

plt.title("E-commerce Funnel Analysis")
plt.xlabel("Funnel Stage")
plt.ylabel("Number of Events")

plt.show()